---
interface Props {
  /** Color that the wave fills — should match the background of the section BELOW */
  fill?: string;
  /** Flip vertically (wave curves upward instead of downward) */
  flip?: boolean;
  class?: string;
}

const {
  fill = '#faf7f2',
  flip = false,
  class: className,
} = Astro.props;
---

<div
  class:list={['wave-divider', { 'wave-divider--flip': flip }, className]}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 1440 48"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path d="M0,48 L0,20 C360,48 1080,0 1440,20 L1440,48 Z" fill={fill} />
  </svg>
</div>

<style>
  .wave-divider {
    position: relative;
    width: 100%;
    overflow: hidden;
    line-height: 0;
    font-size: 0;
  }

  .wave-divider svg {
    display: block;
    width: 100%;
    height: 50px;
  }

  .wave-divider--flip {
    transform: scaleY(-1);
  }
</style>
