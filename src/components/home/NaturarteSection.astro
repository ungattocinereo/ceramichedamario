---
import { Image } from 'astro:assets';
import { getImage } from '../../utils/images';

const naturarteImg = await getImage('/src/assets/images/site/verticale-tramonto-etc.jpg');
---

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <!-- Photo -->
      <div data-animate="fade-in-from-left">
        {naturarteImg ? (
          <Image
            src={naturarteImg}
            alt="Naturarte Project - ceramic art installation in Praiano"
            class="rounded-[10px] card-shadow-lg w-full"
            widths={[400, 700]}
            sizes="(max-width: 1024px) 100vw, 50vw"
          />
        ) : (
          <div class="bg-gray-200 rounded-[10px] aspect-[4/3]" />
        )}
      </div>

      <!-- Text -->
      <div data-animate="fade-in-from-bottom">
        <p class="eyebrow text-muted mb-2">Art works installed around the town are part of the</p>
        <h2 class="page-subtitle mb-6">Naturarte Project</h2>
        <p class="text-muted leading-relaxed">
          Artists from around Italy were invited to create works inspired by the local traditions
          of Praiano and the Amalfi Coast. The result is an extraordinary open-air museum where
          ceramic art meets nature — a unique "street art" experience that blends contemporary
          creativity with centuries-old craftsmanship. Walking through Praiano, you'll discover
          these installations at every turn, each one telling a story of the sea, the land,
          and the people who have called this place home for generations.
        </p>
      </div>
    </div>
  </div>
</section>
