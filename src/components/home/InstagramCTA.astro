---
import siteConfig from '../../data/site-config.json';
import { defaultLocale, type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
---

<section class="bg-[#F5B749] pt-10 pb-16 lg:pt-14 lg:pb-24 text-center">
  <div class="max-w-7xl mx-auto px-6">
    <h2 style="font-family: 'Pacifico', cursive; font-weight: 400;" class="text-black text-[clamp(40px,6vw,80px)] leading-snug">{t('instagram.heading').split('{instagram}')[0]}<span class="underline-pacifico-accent--white">{t('instagram.instagramWord')}</span>{t('instagram.heading').split('{instagram}')[1]}</h2>
    <p class="text-black/80 mt-4 text-sm tracking-wide">
      {t('instagram.followText')}{' '}
      <a
        href={siteConfig.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold text-black underline underline-offset-4 hover:opacity-70 transition-opacity"
      >CeramicheDaMarioPraiano</a>
    </p>
  </div>
</section>
