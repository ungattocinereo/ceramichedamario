---
import { Image } from 'astro:assets';
import { getImage } from '../../utils/images';
import { ForkKnife, FlowerLotus, Fish, Crown, Lamp, CirclesFour, FrameCorners } from '@phosphor-icons/react';

const categories = [
  {
    name: 'Ceramics',
    slug: 'ceramics',
    image: '/src/assets/images/site/ceramichedamario-new-sunset.jpg',
    icon: CirclesFour,
    gridClass: 'col-span-2 row-span-2',
  },
  {
    name: 'Decoration',
    slug: 'decor',
    image: '/src/assets/images/site/14-fish-ceramicadamario.jpg',
    icon: FlowerLotus,
    gridClass: '',
  },
  {
    name: 'Kitchen',
    slug: 'kitchen',
    image: '/src/assets/images/site/table-ceramica.jpg',
    icon: ForkKnife,
    gridClass: '',
  },
  {
    name: "Moro's Heads",
    slug: 'teste-di-moro',
    image: '/src/assets/images/site/ceramichedamario00111.jpg',
    icon: Crown,
    gridClass: '',
  },
  {
    name: 'Wall Plates',
    slug: 'piatti-murali',
    image: '/src/assets/images/site/da-mario-fountain.jpg',
    icon: FrameCorners,
    gridClass: '',
  },
  {
    name: 'Fishes Decor',
    slug: 'pesci',
    image: '/src/assets/images/site/3Linea-Praia-pesci.jpg',
    icon: Fish,
    gridClass: 'col-span-2',
  },
  {
    name: 'Table Lamps',
    slug: 'lampadine',
    image: '/src/assets/images/site/ceramichedamario-111.jpg',
    icon: Lamp,
    gridClass: '',
  },
];

const loaded = await Promise.all(
  categories.map(async (cat) => {
    const img = await getImage(cat.image);
    return { ...cat, img };
  })
);
---

<section class="py-12 lg:py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 auto-rows-[200px]">
      {loaded.map((cat) => {
        const Icon = cat.icon;
        return (
          <a
            href={`/shop/${cat.slug}`}
            class:list={[
              'relative group overflow-hidden rounded-xl',
              cat.gridClass,
            ]}
          >
            {cat.img ? (
              <Image
                src={cat.img}
                alt={cat.name}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                widths={[400, 700]}
                sizes="(max-width: 768px) 50vw, 25vw"
              />
            ) : (
              <div class="absolute inset-0 bg-gray-200" />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent group-hover:from-black/60 transition-all duration-300" />
            <div class="absolute bottom-0 left-0 p-4 flex items-center gap-2">
              <Icon size={18} className="text-white/80" weight="bold" />
              <h3 class="text-white text-base font-bold drop-shadow-lg">{cat.name}</h3>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
