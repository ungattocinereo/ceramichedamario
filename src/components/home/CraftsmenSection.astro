---
import GradientText from '../ui/GradientText.astro';
import { defaultLocale, type Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
---

<section class="py-16 lg:py-24" data-animate="fade-in-from-bottom">
  <div class="max-w-7xl mx-auto px-6">
    <GradientText tag="h2" class="page-subtitle text-center mb-12 max-w-4xl mx-auto">
      {t('craftsmen.heading')}
    </GradientText>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 max-w-5xl mx-auto">
      <div class="text-muted leading-relaxed">
        <p>{t('craftsmen.textLeft')}</p>
      </div>
      <div class="text-muted leading-relaxed">
        <p>{t('craftsmen.textRight')}</p>
      </div>
    </div>
  </div>
</section>
