---
import SplitLineHeading from '../ui/SplitLineHeading.astro';
import Button from '../ui/Button.astro';
import { Package, SealCheck } from '@phosphor-icons/react';
---

<section class="py-16 lg:py-24" data-animate="fade-in-from-bottom">
  <div class="max-w-7xl mx-auto px-6">
    <SplitLineHeading
      lines={['Bring home the Amalfi Coast,', 'gift an emotion from Praiano.']}
      tag="h2"
      class="text-center mb-12"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
      <!-- Shipping -->
      <div class="text-center">
        <div class="w-16 h-16 mx-auto mb-4 text-orange">
          <Package size={64} />
        </div>
        <h3 class="font-bold text-lg uppercase tracking-wide mb-3">Shipping Worldwide</h3>
        <p class="text-muted leading-relaxed">
          After your order we can talk all the details and will arrange the shipment.
          We carefully pack each ceramic piece to ensure it arrives safely to your doorstep, anywhere in the world.
        </p>
      </div>

      <!-- Quality -->
      <div class="text-center">
        <div class="w-16 h-16 mx-auto mb-4 text-orange">
          <SealCheck size={64} />
        </div>
        <h3 class="font-bold text-lg uppercase tracking-wide mb-3">Traditional Quality Products</h3>
        <p class="text-muted leading-relaxed">
          Ceramiche da Mario is located in the heart of Praiano, on the beautiful Amalfi Coast.
          Every piece is handmade and hand-painted by skilled local artisans from Vietri sul Mare.
        </p>
      </div>
    </div>

    <div class="text-center mt-10">
      <Button href="/shop" variant="underline">To the shop</Button>
    </div>
  </div>
</section>
