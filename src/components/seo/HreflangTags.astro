---
import { locales, type Locale } from '../../i18n/config';
import { localizedPath } from '../../i18n/utils';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const siteUrl = 'https://ceramichedamario.it';
---

{locales.map((loc) => (
  <link rel="alternate" hreflang={loc} href={`${siteUrl}${localizedPath(loc, path)}`} />
))}
<link rel="alternate" hreflang="x-default" href={`${siteUrl}${path}`} />
