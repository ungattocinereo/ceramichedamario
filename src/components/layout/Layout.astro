---
import Header from './Header.astro';
import Footer from './Footer.astro';
import WaveDivider from '../ui/WaveDivider.astro';
import CookieBanner from '../ui/CookieBanner.tsx';
import HreflangTags from '../seo/HreflangTags.astro';
import '../../styles/global.css';
import { defaultLocale, localeConfig, type Locale } from '../../i18n/config';
import { stripLocaleFromPath, useTranslations, getTranslations, localizedPath } from '../../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
  isHeroPage?: boolean;
  locale?: Locale;
}

const {
  title = 'Ceramiche Da Mario \u2013 fine ceramics shop in Praiano, Amalfi Coast, Italy',
  description = 'One of the best authentic ceramics shops in Amalfi Coast, famous ceramics of Vietri sul Mare. Traditional quality italian presents',
  ogImage = '/og-image.jpg',
  canonicalUrl,
  jsonLd,
  isHeroPage = false,
  locale = defaultLocale,
} = Astro.props;

const t = useTranslations(locale);
const tr = getTranslations(locale);
const siteUrl = 'https://ceramichedamario.it';
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;
const currentPath = stripLocaleFromPath(Astro.url.pathname);
const ogLocale = localeConfig[locale].ogLocale;

const cookieLabels = {
  message: tr.cookie.message,
  accept: tr.cookie.accept,
  reject: tr.cookie.reject,
  privacyPolicy: tr.cookie.privacyPolicy,
  privacyHref: localizedPath(locale, '/privacy'),
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon-192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#F5B749" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang -->
    <HreflangTags locale={locale} path={currentPath} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Ceramiche Da Mario" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,700;1,9..40,400&family=Pacifico&family=Poppins:wght@500&display=swap"
      rel="stylesheet"
    />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-D7Z0R0WJ6L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-D7Z0R0WJ6L');
    </script>

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Default Organization JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Ceramiche Da Mario",
      "description": "Fine ceramics shop in Praiano, Amalfi Coast",
      "url": siteUrl,
      "telephone": "+39 338 361 2306",
      "email": "ceramichedamario@hotmail.it",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Piazzetta Gennaro Gagliano 108",
        "addressLocality": "Praiano",
        "addressRegion": "SA",
        "postalCode": "84010",
        "addressCountry": "IT"
      },
      "foundingDate": "1960",
      "sameAs": [
        "https://www.instagram.com/ceramichedamariopraiano/",
        "https://www.facebook.com/ceramichedamario"
      ]
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header isHeroPage={isHeroPage} locale={locale} />
    <main class:list={['flex-1', !isHeroPage && 'pt-[72px]']}>
      <slot />
    </main>
    <WaveDivider fill="#3a3a3a" class="-mt-[50px] -mb-px relative z-10" />
    <Footer locale={locale} />
    <CookieBanner labels={cookieLabels} client:load />
    <script src="../../scripts/scroll-animations.ts"></script>
  </body>
</html>
