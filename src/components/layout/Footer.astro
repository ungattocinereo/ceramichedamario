---
import siteConfig from '../../data/site-config.json';
import { InstagramLogo, FacebookLogo, WhatsappLogo, GoogleLogo, Envelope, MapPin, Phone, ArrowRight, ForkKnife, FrameCorners, FlowerLotus, Crown, Lamp, Storefront, CirclesFour } from '@phosphor-icons/react';
---

<footer class="bg-[#3a3a3a] text-white">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Col 1: Brand -->
      <div>
        <h3 class="text-xl font-bold mb-2">Ceramiche Da Mario</h3>
        <p class="text-sm text-white/60 mb-4">Family-run ceramics shop in Praiano since 1960. Handmade and hand-painted Vietri ceramics — plates, décor, table lamps, and more. We ship worldwide.</p>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/ceramichedamariopraiano/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:opacity-70 transition-opacity">
            <InstagramLogo size={20} weight="fill" />
          </a>
          <a href="https://www.facebook.com/ceramichedamario" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:opacity-70 transition-opacity">
            <FacebookLogo size={20} weight="fill" />
          </a>
          <a href="https://wa.me/+393383612306" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="hover:opacity-70 transition-opacity">
            <WhatsappLogo size={20} weight="fill" />
          </a>
          <a href="https://g.page/ceramiche-da-mario" target="_blank" rel="noopener noreferrer" aria-label="Google Maps" class="hover:opacity-70 transition-opacity">
            <GoogleLogo size={20} weight="fill" />
          </a>
          <a href="mailto:Ceramichedamario@hotmail.it" aria-label="Email" class="hover:opacity-70 transition-opacity">
            <Envelope size={20} weight="fill" />
          </a>
        </div>
      </div>

      <!-- Col 2: Shop categories -->
      <div>
        <h4 class="eyebrow mb-3">Shop</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/shop/kitchen" class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><ForkKnife size={14} /> Kitchen</a></li>
          <li><a href="/shop/piatti-murali" class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><FrameCorners size={14} /> Wall Plates</a></li>
          <li><a href="/shop/decor" class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><FlowerLotus size={14} /> Decoration</a></li>
          <li><a href="/shop/teste-di-moro" class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><Crown size={14} /> Moro's Heads</a></li>
          <li><a href="/shop/lampadine" class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><Lamp size={14} /> Table Lamps</a></li>
          <li><a href="/shop/linea-piazzetta" class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><CirclesFour size={14} /> Collections</a></li>
          <li><a href="/shop" class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><Storefront size={14} /> All Products</a></li>
        </ul>
      </div>

      <!-- Col 3: Info -->
      <div>
        <h4 class="eyebrow mb-3">Info</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="text-white/60 hover:text-white transition-colors">About Us</a></li>
          <li><a href="/news" class="text-white/60 hover:text-white transition-colors">News</a></li>
          <li><a href="/contact" class="text-white/60 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div>
        <h4 class="eyebrow mb-3">Contact</h4>
        <address class="not-italic text-sm text-white/60 space-y-2">
          <p class="flex gap-1.5">
            <MapPin size={16} className="shrink-0 mt-0.5" />
            <span>{siteConfig.address.street},<br />{siteConfig.address.postalCode} {siteConfig.address.city} ({siteConfig.address.province})</span>
          </p>
          <p>
            <Phone size={16} className="inline -mt-0.5 mr-1" />
            <a href={`tel:${siteConfig.phone}`} class="hover:text-black transition-colors">{siteConfig.phone}</a>
          </p>
          <p>
            <Envelope size={16} className="inline -mt-0.5 mr-1" />
            <a href={`mailto:${siteConfig.email}`} class="hover:text-black transition-colors">{siteConfig.email}</a>
          </p>
          <p class="pt-1">
            <a
              href={siteConfig.googleMaps}
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/80 hover:text-white hover:underline text-sm font-medium"
            >
              Get Directions <ArrowRight size={14} className="inline ml-0.5" />
            </a>
          </p>
        </address>
      </div>
    </div>
  </div>

  <!-- Copyright & Legal -->
  <div class="border-t border-white/10 py-6 text-xs text-white/40">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row md:justify-between md:items-center gap-3 text-center md:text-left">
      <div class="space-y-0.5">
        <p>&copy; 2020-{new Date().getFullYear()} Ceramiche Da Mario. Praiano, Amalfi Coast, Italy.</p>
        <p>{siteConfig.legal.companyName}</p>
        <p>{siteConfig.legal.registeredOffice} — Italy</p>
        <p>P.IVA / C.F.: {siteConfig.legal.vatId} | REA: {siteConfig.legal.rea}</p>
      </div>
      <div class="md:text-right">
        <a href="/privacy" class="hover:text-white transition-colors underline">Privacy Policy</a>
        <span class="mx-2">|</span>
        <a href="/return-policy" class="hover:text-white transition-colors underline">Return Policy</a>
      </div>
    </div>
  </div>
</footer>
