---
import siteConfig from '../../data/site-config.json';
import { InstagramLogo, FacebookLogo, WhatsappLogo, GoogleLogo, Envelope, MapPin, Phone, ArrowRight, ForkKnife, FlowerLotus, Flower, Storefront, CirclesFour } from '@phosphor-icons/react';
import { defaultLocale, type Locale } from '../../i18n/config';
import { useTranslations, localizedPath } from '../../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="bg-[#3a3a3a] text-white">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Col 1: Brand -->
      <div>
        <h3 class="text-xl font-bold mb-2">Ceramiche Da Mario</h3>
        <p class="text-sm text-white/60 mb-4">{t('footer.description')}</p>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/ceramichedamariopraiano/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:opacity-70 transition-opacity">
            <InstagramLogo size={20} weight="fill" />
          </a>
          <a href="https://www.facebook.com/ceramichedamario" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:opacity-70 transition-opacity">
            <FacebookLogo size={20} weight="fill" />
          </a>
          <a href="https://wa.me/+393383612306" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="hover:opacity-70 transition-opacity">
            <WhatsappLogo size={20} weight="fill" />
          </a>
          <a href="https://g.page/ceramiche-da-mario" target="_blank" rel="noopener noreferrer" aria-label="Google Maps" class="hover:opacity-70 transition-opacity">
            <GoogleLogo size={20} weight="fill" />
          </a>
          <a href="mailto:Ceramichedamario@hotmail.it" aria-label="Email" class="hover:opacity-70 transition-opacity">
            <Envelope size={20} weight="fill" />
          </a>
        </div>
      </div>

      <!-- Col 2: Shop categories -->
      <div>
        <h4 class="eyebrow mb-3">{t('footer.shopHeading')}</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={localizedPath(locale, '/shop/fine-ceramics')} class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><FlowerLotus size={14} /> {t('cat.fineCeramics')}</a></li>
          <li><a href={localizedPath(locale, '/shop/kitchen')} class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><ForkKnife size={14} /> {t('cat.kitchenObjects')}</a></li>
          <li><a href={localizedPath(locale, '/shop/decor')} class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><Flower size={14} /> {t('cat.decoration')}</a></li>
          <li><a href={localizedPath(locale, '/shop/linea-piazzetta')} class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><CirclesFour size={14} /> {t('nav.collections')}</a></li>
          <li><a href={localizedPath(locale, '/shop')} class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"><Storefront size={14} /> {t('cat.allProducts')}</a></li>
        </ul>
      </div>

      <!-- Col 3: Info -->
      <div>
        <h4 class="eyebrow mb-3">{t('footer.infoHeading')}</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={localizedPath(locale, '/about')} class="text-white/60 hover:text-white transition-colors">&mdash; {t('footer.aboutUs')}</a></li>
          <li><a href={localizedPath(locale, '/news')} class="text-white/60 hover:text-white transition-colors">&mdash; {t('nav.news')}</a></li>
          <li><a href={localizedPath(locale, '/contact')} class="text-white/60 hover:text-white transition-colors">&mdash; {t('nav.contact')}</a></li>
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div>
        <h4 class="eyebrow mb-3">{t('footer.contactHeading')}</h4>
        <address class="not-italic text-sm text-white/60 space-y-2">
          <p class="flex gap-1.5">
            <MapPin size={16} className="shrink-0 mt-0.5" />
            <span>{siteConfig.address.street},<br />{siteConfig.address.postalCode} {siteConfig.address.city} ({siteConfig.address.province})</span>
          </p>
          <p>
            <Phone size={16} className="inline -mt-0.5 mr-1" />
            <a href={`tel:${siteConfig.phone}`} class="hover:text-black transition-colors">{siteConfig.phone}</a>
          </p>
          <p>
            <Envelope size={16} className="inline -mt-0.5 mr-1" />
            <a href={`mailto:${siteConfig.email}`} class="hover:text-black transition-colors">{siteConfig.email}</a>
          </p>
          <p class="pt-1">
            <a
              href={siteConfig.googleMaps}
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/80 hover:text-white hover:underline text-sm font-medium"
            >
              {t('footer.getDirections')} <ArrowRight size={14} className="inline ml-0.5" />
            </a>
          </p>
        </address>
      </div>
    </div>
  </div>

  <!-- Copyright & Legal -->
  <div class="border-t border-white/10 py-6 text-xs text-white/40">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row md:justify-between md:items-end gap-3 text-center md:text-left">
      <div class="space-y-0.5">
        <p>&copy; 2020-{new Date().getFullYear()} Ceramiche Da Mario. Praiano, Amalfi Coast, Italy.</p>
        <p>{siteConfig.legal.companyName}</p>
        <p>{siteConfig.legal.registeredOffice} &mdash; Italy</p>
        <p>P.IVA / C.F.: {siteConfig.legal.vatId} | REA: {siteConfig.legal.rea}</p>
      </div>
      <div class="md:text-right space-y-1">
        <div>
          <a href={localizedPath(locale, '/privacy')} class="hover:text-white transition-colors underline">{t('footer.privacyPolicy')}</a>
          <span class="mx-2">|</span>
          <a href={localizedPath(locale, '/return-policy')} class="hover:text-white transition-colors underline">{t('footer.returnPolicy')}</a>
        </div>
        <p class="font-mono">Design &amp; Development Gregory '<a href="https://cinereo.it" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors underline">Cinereo</a>' Smirnov</p>
      </div>
    </div>
    </div>
  </div>
</footer>
