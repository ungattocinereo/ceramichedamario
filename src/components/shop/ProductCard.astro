---
import { Image } from 'astro:assets';
import PriceDisplay from './PriceDisplay.astro';
import { getImage } from '../../utils/images';
import { defaultLocale, type Locale } from '../../i18n/config';
import { localizedPath } from '../../i18n/utils';

interface Props {
  slug: string;
  title: string;
  price: number | null;
  regularPrice?: number | null;
  salePrice?: number | null;
  featuredImage: string | null;
  locale?: Locale;
}

const { slug, title, price, regularPrice, salePrice, featuredImage, locale = defaultLocale } = Astro.props;
const img = featuredImage ? await getImage(featuredImage) : null;
---

<a href={localizedPath(locale, `/shop/${slug}`)} class="block group">
  <div class="rounded-[10px] overflow-hidden bg-gray-50 aspect-square mb-3 transition-shadow duration-300 group-hover:shadow-lg">
    {img ? (
      <Image
        src={img}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        widths={[300, 500]}
        sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-muted text-sm">No image</div>
    )}
  </div>
  <h3 class="text-sm font-medium mb-1 group-hover:text-primary transition-colors line-clamp-2">
    {title}
  </h3>
  <PriceDisplay price={price} regularPrice={regularPrice} salePrice={salePrice} class="text-sm" locale={locale} />
</a>
