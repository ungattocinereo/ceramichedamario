---
import Layout from '../../components/layout/Layout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { House } from '@phosphor-icons/react';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout
  title="News - Ceramiche Da Mario"
  description="Latest news and updates from Ceramiche Da Mario in Praiano, Amalfi Coast."
>
  <div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-muted mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-primary inline-flex items-center gap-1"><House size={14} /> Home</a>
      <span class="mx-2">/</span>
      <span>News</span>
    </nav>

    <h1 class="text-3xl font-bold mb-8">News</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {sortedPosts.map((post) => (
        <PostCard
          slug={post.data.slug}
          title={post.data.title}
          date={post.data.date}
          featuredImage={post.data.featuredImage}
        />
      ))}
    </div>
  </div>
</Layout>
