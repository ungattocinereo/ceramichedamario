---
import Layout from '../../components/layout/Layout.astro';
import PriceDisplay from '../../components/shop/PriceDisplay.astro';
import ProductCard from '../../components/shop/ProductCard.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { getImage } from '../../utils/images';
import { House, Scales, Barcode, Tag, Envelope } from '@phosphor-icons/react';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product: product.data },
  }));
}

const { product } = Astro.props;

// Load featured image
const featuredImg = product.featuredImage ? await getImage(product.featuredImage) : null;

// Load gallery images
const galleryImages = await Promise.all(
  product.galleryImages.map(async (path) => {
    const img = await getImage(path);
    return img ? { src: img, path } : null;
  })
);
const validGallery = galleryImages.filter(Boolean);

// Related products (same category, max 4)
const allProducts = await getCollection('products');
const related = allProducts
  .filter(p =>
    p.data.slug !== product.slug &&
    p.data.categories.some(c =>
      product.categories.some(pc => pc.slug === c.slug)
    )
  )
  .slice(0, 4);

// JSON-LD Product schema
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.title,
  "description": product.excerpt || product.description?.replace(/<[^>]*>/g, ''),
  "url": `https://ceramichedamario.com/shop/${product.slug}`,
  "brand": {
    "@type": "Brand",
    "name": "Ceramiche Da Mario"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Ceramiche Da Mario",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Praiano",
      "addressRegion": "Amalfi Coast",
      "addressCountry": "IT"
    }
  },
  "material": "Hand-painted ceramic",
  "countryOfOrigin": "IT",
  "isHandmade": true,
  ...(product.sku && { "sku": product.sku }),
  ...(product.weight && { "weight": { "@type": "QuantitativeValue", "value": product.weight, "unitCode": "KGM" } }),
  ...(product.categories.length > 0 && { "category": product.categories.map(c => c.name).join(', ') }),
  ...(product.price !== null && {
    "offers": {
      "@type": "Offer",
      "price": product.price,
      "priceCurrency": "EUR",
      "availability": product.stockStatus === 'instock'
        ? "https://schema.org/InStock"
        : "https://schema.org/OutOfStock",
      "seller": {
        "@type": "Organization",
        "name": "Ceramiche Da Mario"
      },
      "itemCondition": "https://schema.org/NewCondition",
      "priceValidUntil": new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
    }
  }),
};

// BreadcrumbList schema
const primaryCategory = product.categories[0];
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ceramichedamario.com/" },
    { "@type": "ListItem", "position": 2, "name": "Shop", "item": "https://ceramichedamario.com/shop" },
    ...(primaryCategory ? [{ "@type": "ListItem", "position": 3, "name": primaryCategory.name, "item": `https://ceramichedamario.com/shop/${primaryCategory.slug}` }] : []),
    { "@type": "ListItem", "position": primaryCategory ? 4 : 3, "name": product.title },
  ],
};
---

<Layout
  title={product.seoTitle}
  description={product.seoDescription}
  jsonLd={{ "@context": "https://schema.org", "@graph": [jsonLd, breadcrumbLd].map(({["@context"]: _, ...rest}) => rest) }}
>
  <div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-muted mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-primary inline-flex items-center gap-1"><House size={14} /> Home</a>
      <span class="mx-2">/</span>
      <a href="/shop" class="hover:text-primary">Shop</a>
      {primaryCategory && (
        <>
          <span class="mx-2">/</span>
          <a href={`/shop/${primaryCategory.slug}`} class="hover:text-primary">{primaryCategory.name}</a>
        </>
      )}
      <span class="mx-2">/</span>
      <span>{product.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">
      <!-- Images -->
      <div>
        {/* Main image */}
        {featuredImg ? (
          <div class="rounded-[10px] overflow-hidden mb-4">
            <Image
              src={featuredImg}
              alt={product.title}
              class="w-full"
              widths={[500, 800]}
              sizes="(max-width: 1024px) 100vw, 50vw"
            />
          </div>
        ) : (
          <div class="bg-gray-100 rounded-[10px] aspect-square flex items-center justify-center text-muted mb-4">
            No image available
          </div>
        )}

        {/* Gallery thumbnails */}
        {validGallery.length > 0 && (
          <div class="grid grid-cols-4 gap-2">
            {validGallery.map((g) => g && (
              <div class="rounded-lg overflow-hidden aspect-square">
                <Image
                  src={g.src}
                  alt={`${product.title} gallery`}
                  class="w-full h-full object-cover"
                  widths={[150, 250]}
                  sizes="(max-width: 1024px) 25vw, 12vw"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Product info -->
      <div>
        <h1 class="text-3xl lg:text-4xl font-bold mb-4">{product.title}</h1>

        <PriceDisplay
          price={product.price}
          regularPrice={product.regularPrice}
          salePrice={product.salePrice}
          class="text-2xl mb-6"
        />

        {/* Description with expand/collapse */}
        {(product.excerpt || product.description) && (
          <div class="mb-6">
            {/* Excerpt — always visible */}
            {product.excerpt && (
              <p class="text-muted leading-relaxed">{product.excerpt}</p>
            )}

            {/* Full description — expandable */}
            {product.description && (
              <div class="mt-3">
                {product.description.includes('<') ? (
                  <div
                    id="product-description"
                    class="prose prose-sm max-w-none text-muted leading-relaxed overflow-hidden transition-[max-height,opacity] duration-500 ease-in-out max-h-0 opacity-0"
                    set:html={product.description}
                  />
                ) : (
                  <div
                    id="product-description"
                    class="space-y-4 text-sm text-muted leading-relaxed overflow-hidden transition-[max-height,opacity] duration-500 ease-in-out max-h-0 opacity-0"
                  >
                    {product.description.split('\n\n').map((p) => (
                      <p>{p}</p>
                    ))}
                  </div>
                )}
                <button
                  id="toggle-description"
                  type="button"
                  class="inline-flex items-center gap-1.5 mt-3 text-sm font-medium text-primary hover:text-primary/80 transition-colors cursor-pointer"
                >
                  <span id="toggle-text">Read more</span>
                  <svg
                    id="toggle-arrow"
                    class="w-4 h-4 transition-transform duration-300"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              </div>
            )}
          </div>
        )}

        {/* Meta info */}
        <div class="space-y-2 text-sm text-muted mb-8">
          {product.weight && (
            <p><Scales size={14} className="inline -mt-0.5 mr-1" /><span class="font-medium text-black">Weight:</span> {product.weight} kg</p>
          )}
          {product.sku && (
            <p><Barcode size={14} className="inline -mt-0.5 mr-1" /><span class="font-medium text-black">SKU:</span> {product.sku}</p>
          )}
          {product.categories.length > 0 && (
            <p>
              <Tag size={14} className="inline -mt-0.5 mr-1" /><span class="font-medium text-black">Categories:</span>{' '}
              {product.categories.map((c, i) => (
                <>
                  <a href={`/shop/${c.slug}`} class="text-primary hover:underline">{c.name}</a>
                  {i < product.categories.length - 1 && ', '}
                </>
              ))}
            </p>
          )}
        </div>

        {/* CTA */}
        <a
          href={`/contact?product=${encodeURIComponent(product.title)}`}
          class="btn btn-primary inline-block"
        >
          <Envelope size={16} className="inline -mt-0.5 mr-1" /> Request a Quote
        </a>
      </div>
    </div>

    {/* Related Products */}
    {related.length > 0 && (
      <section class="mt-16 pt-12 border-t border-gray-100">
        <h2 class="text-2xl font-bold mb-8">Related Products</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {related.map((p) => (
            <ProductCard
              slug={p.data.slug}
              title={p.data.title}
              price={p.data.price}
              featuredImage={p.data.featuredImage}
            />
          ))}
        </div>
      </section>
    )}
  </div>

  <script>
    const btn = document.getElementById('toggle-description');
    const desc = document.getElementById('product-description');
    const text = document.getElementById('toggle-text');
    const arrow = document.getElementById('toggle-arrow');

    if (btn && desc) {
      btn.addEventListener('click', () => {
        const isOpen = desc.classList.contains('max-h-0');
        if (isOpen) {
          desc.classList.remove('max-h-0', 'opacity-0');
          desc.classList.add('max-h-[1000px]', 'opacity-100');
          arrow?.classList.add('rotate-180');
          if (text) text.textContent = 'Show less';
        } else {
          desc.classList.add('max-h-0', 'opacity-0');
          desc.classList.remove('max-h-[1000px]', 'opacity-100');
          arrow?.classList.remove('rotate-180');
          if (text) text.textContent = 'Read more';
        }
      });
    }
  </script>
</Layout>
